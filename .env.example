# Base RPC (Alchemy, QuickNode, or public)
BASE_RPC_URL=https://mainnet.base.org

# Server port
PORT=3402

# x402 Configuration (Phase 1.5)
# USDC receiving address on Base
X402_PAYEE_ADDRESS=0xYOUR_WALLET_ADDRESS
# Coinbase facilitator URL
X402_FACILITATOR_URL=https://x402.coinbase.com

# Supabase (Phase 1.5)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- PROOF-OF-CONTEXT (PoC) ATTESTATION ---
# Vigil emits f_i (input freshness) PoC attestations on every paid response.
# If unset, attestations are returned without signature (still informational).
# Generate a signing key with: cd packages/core && tsx -e "import {randomBytes} from 'crypto'; console.log(randomBytes(32).toString('hex'))"
POC_SIGNING_KEY=
POC_SOURCE_ID=vigil:default
